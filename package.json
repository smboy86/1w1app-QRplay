{
  "name": "qrplay",
  "version": "1.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:sync": "expo prebuild --platform android --no-install",
    "android:clean": "expo run:android --clean",
    "build:apk": "npx eas build --platform android --profile production-apk --local",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.5",
    "expo-camera": "~55.0.9",
    "expo-dev-client": "~55.0.13",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~55.0.8",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true
}
